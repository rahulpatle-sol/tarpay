          "name": "10. Send Payment \u2014 Normal (saves tx_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Transaction created in ON_HOLD\", () => {",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.success).to.be.true;",
                  "  pm.expect(r.transaction.status).to.eql(\"ON_HOLD\");",
                  "  pm.expect(r.transaction.amount).to.eql(500);",
                  "  pm.expect(r.isFlagged).to.be.false;",
                  "  pm.expect(r.releaseAt).to.be.a(\"string\");",
                  "  pm.collectionVariables.set(\"tx_id\", r.transaction.id);",
                  "  pm.collectionVariables.set(\"held_tx_id\", r.transaction.id);",
                  "});",
                  "pm.test(\"Receiver name snapshot saved\", () => {",
                  "  pm.expect(pm.response.json().receiverName).to.be.a(\"string\");",
                  "});"
                ],
