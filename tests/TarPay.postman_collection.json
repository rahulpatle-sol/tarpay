              "mode": "raw",
              "raw": "{\"name\": \"Rajat Samosa Stall\", \"phone\": \"9876543212\", \"upiId\": \"samosa@tarpay\", \"password\": \"password123\", \"isMerchant\": true, \"businessName\": \"Rajat ka Samosa Corner\"}"
            }
          }
        },
        {
          "name": "4. Login \u2014 saves token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Returns JWT token\", () => {",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.success).to.be.true;",
                  "  pm.expect(r.token).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(r.user.upiId).to.eql(\"rahul@tarpay\");",
                  "  pm.collectionVariables.set(\"token\", r.token);",
                  "});",
                  "pm.test(\"Balance is a number\", () => {",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.user.balance).to.be.a(\"number\");",
                  "});"
