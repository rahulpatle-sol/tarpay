  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Service is TarPay\", () => {",
                  "  const r = pm.response.json();",
                  "  pm.expect(r.status).to.eql(\"ok\");",
                  "  pm.expect(r.service).to.include(\"TarPay\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "2. Register User (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Register returns 201 or 409\", () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.test(\"User created with balance\", () => {",
                  "    const r = pm.response.json();",
                  "    pm.expect(r.success).to.be.true;",
                  "    pm.expect(r.user.balance).to.eql(10000);",
                  "    pm.expect(r.user.upiId).to.eql(\"rahul@tarpay\");",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Rahul Sharma\", \"phone\": \"9876543210\", \"upiId\": \"rahul@tarpay\", \"password\": \"password123\", \"isMerchant\": false}"
            }
          }
        },
